@page "/Estudiantes/Index"
@inject EstudiantesService estudiantesService


<PageTitle>Lista de Estudiantes</PageTitle>
<div class="card shadow-lg ">
    <div class="card-header">
        <h3>Registro de Estudiantes</h3>
    </div>

    <div class="card-body">
        @if (estudiantes == null)
        {
            <div class="text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
        }
        else if (!estudiantes.Any())
        {
            <div class="alert alert-info text-center" role="alert">
                No hay estudiantes registrados en la base de datos.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <QuickGrid Items="@estudiantes.AsQueryable()" class="table table-striped table-bordered table-hover">
                    <PropertyColumn Property="@(e => e.EstudianteId)" Title="ID" />
                    <PropertyColumn Property="@(e => e.Nombres)" Title="Nombres" />
                    <PropertyColumn Property="@(e => e.Email)" Title="Email" />
                    <PropertyColumn Property="@(e => e.Edad)" Title="Edad" />
                    <PropertyColumn Property="@(e => e.BalancePuntos)" Title="Balance de Puntos" />
                </QuickGrid>
            </div>
        }
    </div>
</div>



@code {
    private List<Estudiantes>? estudiantes;
    protected override async Task OnInitializedAsync()
    {
        estudiantes = await estudiantesService.Listar(e => true);
    }

}
